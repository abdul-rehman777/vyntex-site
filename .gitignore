.vscode/*
!.vscode/extensions.json
.idea/

# ---- OS metadata ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ---- deployment ----
.vercel

# ---- packaging: never commit a build archive back into the repo ----
*.zip
