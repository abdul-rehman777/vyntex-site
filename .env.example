# =========================================================================
# VYNTEX — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. Only NEXT_PUBLIC_* vars reach the browser.
# There are NO real secrets in this file.
# =========================================================================

# ---- Site ----------------------------------------------------------------
# Canonical apex URL. Used for metadata, sitemap, robots, email links, and the
# Square checkout redirect URL.
NEXT_PUBLIC_SITE_URL=https://vyntexusa.com

# ---- Supabase (auth, database, agreement storage) ------------------------
# Public values (safe for the browser):
NEXT_PUBLIC_SUPABASE_URL=https://phtpogiaupzdsueodiqj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ZR3vv_8GH6VDkdqcAzNF8A_K8yx9OcO
# Server-only. Bypasses Row Level Security — NEVER expose to the client.
# Used for: writing applications/orders/agreements, the Square webhook, and
# signing URLs for the private `agreements` storage bucket.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Resend (transactional email) ----------------------------------------
RESEND_API_KEY=
# From address for outgoing email. Must be on a Resend-verified domain.
FROM_EMAIL=info@vyntexusa.com
# Preferred internal recipient (falls back to INTERNAL_INBOX, then site email).
CONTACT_TO_EMAIL=info@vyntexusa.com
# All internal notifications are sent here.
INTERNAL_INBOX=info@vyntexusa.com
# Secret salt used to hash IPs before they are stored. Raw IPs are never
# persisted. Generate with: openssl rand -hex 32
IP_HASH_SALT=

# ---- Upstash Redis (rate limiting) ---------------------------------------
# Leave blank locally; limiters degrade to a permissive fallback AND log a
# loud error in production. Set these before going live.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Square (hosted checkout + webhooks) ---------------------------------
# "sandbox" or "production".
SQUARE_ENVIRONMENT=sandbox
# Server-only access token. NEVER prefix with NEXT_PUBLIC_.
SQUARE_ACCESS_TOKEN=
# The location that receives the payment (Square Dashboard > Locations).
SQUARE_LOCATION_ID=
# Webhook signature key from Square Developer > Webhooks > Subscriptions.
# Without this, the webhook route rejects every request — payments will never
# be confirmed. This is intentional: no key, no trust.
SQUARE_WEBHOOK_SIGNATURE_KEY=
# The webhook URL EXACTLY as registered with Square. Square signs
# (notification_url + raw_body), so a mismatch here breaks verification.
# Example: https://vyntexusa.com/api/square/webhook
SQUARE_WEBHOOK_NOTIFICATION_URL=

# ---- Vercel Cron (scheduled jobs) ---------------------------------------
# Vercel sends `Authorization: Bearer $CRON_SECRET` on scheduled invocations.
# The cron routes FAIL CLOSED without this: partner expiry and email retries
# simply will not run. Generate with: openssl rand -hex 32
CRON_SECRET=

# Secondary FormSubmit notification inbox. The first live submission triggers
# a one-time activation email that must be approved in this inbox.
FORMSUBMIT_ENABLED=true
FORMSUBMIT_EMAIL=info@vyntexusa.com
